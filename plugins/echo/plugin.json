{
  "name": "echo-tools",
  "description": "Example local stdio plugin tools for the workspace agent.",
  "command": "node",
  "args": [
    "${pluginDir}/worker.mjs"
  ],
  "tools": [
    {
      "name": "plugin_echo",
      "description": "Echo text back to the agent and optionally uppercase it.",
      "inputSchema": {
        "type": "object",
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "type": "string",
            "description": "Text to echo."
          },
          "uppercase": {
            "type": "boolean",
            "description": "Return the text in uppercase."
          }
        }
      },
      "riskLevel": "low",
      "mutatesWorkspace": false,
      "requiresApproval": false
    }
  ]
}
